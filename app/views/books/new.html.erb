<h1>Add a New Book</h1>

<%= form_with model: @book, local: true do |f| %>
  <div class="field">
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div class="field">
    <%= f.label :author %>
    <%= f.text_field :author %>
  </div>

  <div class="field">
    <%= f.label :available %>
    <%= f.check_box :available %>
  </div>

  <div class="actions">
    <%= f.submit "Add Book" %>
  </div>
<% end %>

<%= link_to "Back to Books", books_path %>
